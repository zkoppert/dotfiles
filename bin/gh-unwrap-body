#!/usr/bin/env python3
"""Unwrap hard-wrapped markdown paragraphs for GitHub rendering.

GitHub renders each literal newline as a line break. This script joins
continuation lines within paragraphs while preserving intentional structure
(headers, lists, tables, code blocks, blank lines).

Usage:
    gh-unwrap-body input.md > output.md
    cat input.md | gh-unwrap-body - > output.md
    gh-unwrap-body --in-place file.md
"""

import re
import sys


def unwrap(text: str) -> str:
    lines = text.split("\n")
    result: list[str] = []
    in_code_block = False
    i = 0

    while i < len(lines):
        line = lines[i]

        if line.strip().startswith("```"):
            in_code_block = not in_code_block
            result.append(line)
            i += 1
            continue

        if in_code_block:
            result.append(line)
            i += 1
            continue

        if line.strip() == "":
            result.append("")
            i += 1
            continue

        if re.match(r"^#{1,6}\s", line):
            result.append(line)
            i += 1
            continue

        if line.strip().startswith("|"):
            result.append(line)
            i += 1
            continue

        # List item - collect continuation lines
        if re.match(r"^(\s*[-*]\s|\s*\d+\.\s)", line):
            joined = line.rstrip()
            while i + 1 < len(lines):
                next_line = lines[i + 1]
                if (
                    next_line.strip() != ""
                    and not re.match(
                        r"^(\s*[-*]\s|\s*\d+\.\s|#{1,6}\s|\||```)", next_line
                    )
                    and (next_line.startswith(" ") or not re.match(r"^[A-Z\[]", next_line))
                ):
                    joined += " " + next_line.strip()
                    i += 1
                else:
                    break
            result.append(joined)
            i += 1
            continue

        # Regular paragraph - join continuation lines
        paragraph = line.rstrip()
        while i + 1 < len(lines):
            next_line = lines[i + 1]
            if next_line.strip() != "" and not re.match(
                r"^(\s*[-*]\s|\s*\d+\.\s|#{1,6}\s|\||```|>)", next_line
            ):
                paragraph += " " + next_line.strip()
                i += 1
            else:
                break
        result.append(paragraph)
        i += 1

    return "\n".join(result)


def main() -> None:
    if len(sys.argv) < 2:
        print(__doc__, file=sys.stderr)
        sys.exit(2)

    in_place = "--in-place" in sys.argv
    files = [a for a in sys.argv[1:] if a != "--in-place"]

    for path in files:
        if path == "-":
            text = sys.stdin.read()
            sys.stdout.write(unwrap(text))
        else:
            with open(path) as f:
                text = f.read()
            output = unwrap(text)
            if in_place:
                with open(path, "w") as f:
                    f.write(output)
            else:
                sys.stdout.write(output)


if __name__ == "__main__":
    main()
