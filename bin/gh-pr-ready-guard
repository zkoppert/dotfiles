#!/bin/bash
# gh wrapper that guards `gh pr ready` against accidental or unconfirmed use.
#
# Why this exists:
#   Marking a draft PR as ready triggers reviewer notifications. Zack's rule
#   is "never mark draft PRs ready without explicit ask." This wrapper adds a
#   second layer of defense behind the text instructions:
#
#     - In an interactive shell (TTY): prompt for confirmation before running.
#     - In a non-interactive shell (e.g., an agent's bash tool): refuse unless
#       the env var ZACK_CONFIRMED_PR_READY=1 is set in the same invocation.
#
# Install:
#   Symlink this script to a directory that comes before the real gh on PATH:
#     ln -sf "$PWD/bin/gh-pr-ready-guard" ~/.local/bin/gh
#   Then ensure ~/.local/bin is first on PATH.
#
# Pass-through:
#   Every gh subcommand other than `gh pr ready` is exec'd against the real
#   gh binary with no modifications.

set -euo pipefail

# Find the real gh binary by skipping our own directory in PATH.
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SELF_REAL_PATH="$(cd "$(dirname "$(readlink "$0" 2>/dev/null || echo "$0")")" && pwd)"

REAL_GH=""
IFS=':' read -ra PATH_ENTRIES <<< "$PATH"
for entry in "${PATH_ENTRIES[@]}"; do
  [ -z "$entry" ] && continue
  candidate="$entry/gh"
  [ ! -x "$candidate" ] && continue
  resolved_dir="$(cd "$entry" 2>/dev/null && pwd || echo "$entry")"
  # Skip if this is our own directory (avoid infinite loop)
  if [ "$resolved_dir" = "$SCRIPT_PATH" ] || [ "$resolved_dir" = "$SELF_REAL_PATH" ]; then
    continue
  fi
  REAL_GH="$candidate"
  break
done

if [ -z "$REAL_GH" ]; then
  echo "gh-pr-ready-guard: real gh binary not found in PATH" >&2
  echo "gh-pr-ready-guard: PATH=$PATH" >&2
  exit 127
fi

# Walks args looking for the `pr ready` subcommand+operation pair, accounting for
# gh's global flags that may precede the subcommand (e.g. `gh -R owner/repo pr ready`).
# Sets the global `is_pr_ready` to 1 if matched, 0 otherwise.
is_pr_ready=0
{
  args=("$@")
  i=0
  subcmd=""
  op=""
  while [ $i -lt ${#args[@]} ]; do
    arg="${args[$i]}"
    case "$arg" in
      -R|--repo|-H|--hostname|--token)
        # These global flags take a value: skip both.
        i=$((i + 2))
        ;;
      --repo=*|--hostname=*|--token=*|--*=*)
        i=$((i + 1))
        ;;
      --version|--help|-h)
        # Self-contained: not a subcommand path.
        break
        ;;
      -*)
        # Unknown leading flag: assume no value and skip.
        i=$((i + 1))
        ;;
      *)
        if [ -z "$subcmd" ]; then
          subcmd="$arg"
          i=$((i + 1))
        elif [ -z "$op" ]; then
          op="$arg"
          break
        fi
        ;;
    esac
  done
  if [ "$subcmd" = "pr" ] && [ "$op" = "ready" ]; then
    is_pr_ready=1
    # `--undo` reverts a ready PR back to draft and does NOT notify reviewers,
    # so it should not trigger the guard.
    for a in "$@"; do
      if [ "$a" = "--undo" ]; then
        is_pr_ready=0
        break
      fi
    done
  fi
}

# Only intercept `gh pr ready`. Everything else passes through unchanged.
if [ "$is_pr_ready" = "1" ]; then
  if [ -t 0 ] && [ -t 1 ]; then
    # Interactive shell: prompt the user.
    echo "About to run: gh $*" >&2
    echo "This marks the PR ready for review and notifies reviewers." >&2
    printf "Continue? [y/N] " >&2
    read -r ans
    case "$ans" in
      y|Y|yes|YES|Yes) ;;
      *) echo "Aborted." >&2; exit 1 ;;
    esac
  else
    # Non-interactive shell (e.g., agent automation): refuse unless explicitly confirmed.
    if [ "${ZACK_CONFIRMED_PR_READY:-}" != "1" ]; then
      cat >&2 <<'EOF'
gh-pr-ready-guard: `gh pr ready` blocked.

Reason: Zack's rule is "never mark draft PRs ready without explicit ask."
This wrapper prevents accidental notifications to reviewers from automation.

If Zack has explicitly confirmed that this PR should be marked ready, set:

  ZACK_CONFIRMED_PR_READY=1 gh pr ready <args>

Otherwise, leave the PR as draft and ask Zack first.
EOF
      exit 1
    fi
  fi
fi

exec "$REAL_GH" "$@"
